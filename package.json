  "repository": {
    "type": "git",
    "url": "https://github.com/SuperInstance/constraint-ranch.git"
  },
  "bugs": {
    "url": "https://github.com/SuperInstance/constraint-ranch/issues"
  },
  "homepage": "https://constraint-theory.superinstance.ai/ranch",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
